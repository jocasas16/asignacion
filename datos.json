const OPERARIOS = ['Manu','Xavi','Pili','Isa','Eva','Memba','Filly','Juan','Mohssin','Aneel','Moustapha','Kissima','ElHadji'];
const MACHINES  = ['E01','E02','E03','I01','I02','I03','I04','I05','I06','I07','I08','I09','I10','I11','I12'];
const OP_COLORS = ['#3b82f6','#6366f1','#22c55e','#f59e0b','#ef4444','#ec4899','#14b8a6','#f97316','#8b5cf6','#06b6d4','#84cc16','#d946ef','#fb923c'];

let state = {};

function machCat(m) { if(m==='E01'||m==='E02'||m==='E03') return m; return 'I'; }

function getMoldeData(machId, molde) {
  if (!molde) return null;
  return (MOLDE_BY_CAT[machCat(machId)] || MOLDE_BY_CAT['I'])[molde] || null;
}

function buildOptions(cat) {
  const dict = MOLDE_BY_CAT[cat] || MOLDE_BY_CAT['I'];
  const keys = Object.keys(dict).sort((a,b)=>{ const na=parseFloat(a),nb=parseFloat(b); return(!isNaN(na)&&!isNaN(nb))?na-nb:a.localeCompare(b); });
  return '<option value="">— Sin molde —</option>'+keys.map(k=>`<option value="${k}">${k} · ${dict[k].desc.substring(0,32)}</option>`).join('');
}

const OPT = { E01:buildOptions('E01'), E02:buildOptions('E02'), E03:buildOptions('E03'), I:buildOptions('I') };
const OP_OPT = '<option value="">— Sin asignar —</option>'+OPERARIOS.map(o=>`<option value="${o}">${o}</option>`).join('');

function loadState() { try { const s=localStorage.getItem('maq_v2'); if(s) state=JSON.parse(s); } catch(e){} }
function saveState() { try { localStorage.setItem('maq_v2',JSON.stringify(state)); flashAutosave(); } catch(e){} }
function resetAll() {
  if(!confirm('¿Limpiar todas las asignaciones?')) return;
  state={}; localStorage.removeItem('maq_v2');
  renderTable(); updateAllOcu(); updateSummary();
}

let _afl;
function flashAutosave() {
  const el = document.getElementById('autosave-label');
  if (!el) return;
  el.style.color = 'var(--green)';
  clearTimeout(_afl);
  _afl = setTimeout(() => { el.style.color = ''; }, 1200);
}

function showToast(m) { const t=document.getElementById('toast'); t.textContent=m; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2000); }
let _ct; function showConflict(m) { const el=document.getElementById('conflict-msg'); el.textContent=m; el.classList.add('show'); clearTimeout(_ct); _ct=setTimeout(()=>el.classList.remove('show'),3000); }

function getOcc(op) {
  let total=0; const machines=[];
  for(const [m,s] of Object.entries(state)) {
    if(s.operario===op && s.molde && !s.stopped) {
      const d=getMoldeData(m,s.molde); const c=d?d.coef:0;
      total+=c; machines.push({machId:m,molde:s.molde,coef:c});
    }
  }
  return {total,machines};
}
function occColor(p) { if(p<=80) return 'ok'; if(p<=100) return 'warn'; if(p<=120) return 'over'; return 'crit'; }
function applyOpColor(sel,op) { if(!op){sel.style.borderColor='';sel.style.color='';return;} const c=OP_COLORS[OPERARIOS.indexOf(op)]||'#3b82f6'; sel.style.borderColor=c; sel.style.color=c; }

function ensureState(m) { if(!state[m]) state[m]={molde:'',operario:'',stopped:false}; }

function renderTable() {
  const tbody=document.getElementById('tbody'); tbody.innerHTML='';
  for(const machId of MACHINES) {
    const type=machId[0].toLowerCase(); const cat=machCat(machId);
    const s=state[machId]||{molde:'',operario:'',stopped:false};
    const tr=document.createElement('tr');
    tr.className=`row-machine type-${type}${s.stopped?' stopped':''}`;
    tr.id=`row-${machId}`;
    tr.innerHTML=`
      <td class="col-stop"><button class="stop-btn${s.stopped?' active':''}" title="Máquina parada" onclick="toggleStop('${machId}')">⏸</button></td>
      <td class="col-id" style="padding:0 8px">
        <div style="display:flex;flex-direction:column;align-items:center">
          <span class="machine-badge badge-${type}">${machId}</span>
          <span class="stopped-label">PARADA</span>
        </div>
      </td>
      <td class="col-molde"><select class="molde-select" id="mol-${machId}">${OPT[cat]}</select></td>
      <td class="col-desc" id="desc-${machId}"></td>
      <td class="col-op"><select class="op-select" id="op-${machId}">${OP_OPT}</select></td>
      <td class="col-ocu" id="ocu-${machId}"></td>`;
    tbody.appendChild(tr);

    const molSel=document.getElementById(`mol-${machId}`);
    molSel.value=s.molde||'';
    updateDesc(machId, s.molde||'');

    const opSel=document.getElementById(`op-${machId}`);
    opSel.value=s.operario||'';
    applyOpColor(opSel, s.operario||'');

    molSel.addEventListener('change', e=>onMoldeChange(machId,e.target.value));
    opSel.addEventListener('change', e=>onOpChange(machId,e.target.value));
  }
}

function onMoldeChange(machId, val) {
  ensureState(machId);
  if (val) {
    for(const [m,s] of Object.entries(state)) {
      if(m!==machId && s.molde===val && !s.stopped) {
        showConflict(`⚠ El molde ${val} ya está asignado a ${m}`);
        const sel=document.getElementById(`mol-${machId}`);
        sel.value=state[machId].molde||'';
        sel.classList.add('conflict');
        setTimeout(()=>sel.classList.remove('conflict'),1500);
        return;
      }
    }
  }
  state[machId].molde=val;
  updateDesc(machId,val);
  updateAllOcu(); updateSummary(); saveState();
}

function onOpChange(machId, val) {
  ensureState(machId);
  state[machId].operario=val;
  applyOpColor(document.getElementById(`op-${machId}`),val);
  updateAllOcu(); updateSummary(); saveState();
}

function toggleStop(machId) {
  ensureState(machId);
  state[machId].stopped=!state[machId].stopped;
  const row=document.getElementById(`row-${machId}`);
  const btn=row.querySelector('.stop-btn');
  if(state[machId].stopped) { row.classList.add('stopped'); btn.classList.add('active'); }
  else { row.classList.remove('stopped'); btn.classList.remove('active'); }
  updateAllOcu(); updateSummary(); saveState();
}

function updateDesc(machId, val) {
  const cell=document.getElementById(`desc-${machId}`); if(!cell) return;
  if(!val) { cell.innerHTML='<span class="desc-text" style="color:#2e3248">—</span>'; return; }
  const d=getMoldeData(machId,val);
  if(!d) { cell.innerHTML=`<span class="desc-text" style="color:#555">${val}</span>`; return; }
  cell.innerHTML=`<div class="desc-text">${d.desc}</div><div class="desc-coef">Coef. ${d.coef}%</div>`;
}

function updateOcuCell(machId) {
  const cell=document.getElementById(`ocu-${machId}`); if(!cell) return;
  const s=state[machId]||{};
  if(!s.operario||!s.molde||s.stopped) { cell.innerHTML='<div class="ocu-display"><span class="ocu-pct" style="color:#2e3248">—</span></div>'; return; }
  const {total}=getOcc(s.operario);
  const cc=occColor(total); const idx=OPERARIOS.indexOf(s.operario); const color=OP_COLORS[idx]||'#3b82f6';
  cell.innerHTML=`<div class="ocu-display"><span class="ocu-pct color-${cc}">${total.toFixed(0)}%</span><div class="ocu-bar-wrap"><div class="ocu-bar" style="width:${Math.min(total,200)/2}%;background:${color}"></div></div></div>`;
}

function updateAllOcu() { for(const m of MACHINES) updateOcuCell(m); }

function updateSummary() {
  const bar=document.getElementById('summary-bar'); bar.innerHTML='';
  for(const op of OPERARIOS) {
    const {total,machines}=getOcc(op); if(!machines.length) continue;
    const idx=OPERARIOS.indexOf(op); const color=OP_COLORS[idx]; const cc=occColor(total);
    const chip=document.createElement('div'); chip.className='op-chip';
    chip.innerHTML=`<div class="op-chip-dot" style="background:${color}"></div><span class="op-chip-name">${op}</span><span class="op-chip-pct color-${cc}">${total.toFixed(0)}%</span>`;
    bar.appendChild(chip);
  }
  renderPanel();
}

function renderPanel() {
  const c=document.getElementById('panel-content'); c.innerHTML='';
  const stopped=MACHINES.filter(m=>state[m]?.stopped);
  if(stopped.length) {
    c.innerHTML+=`<div style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:10px;padding:10px 14px;margin-bottom:14px"><div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;color:#ef4444;letter-spacing:1px;margin-bottom:6px">⏸ MÁQUINAS PARADAS</div><div style="font-size:13px">${stopped.join('  ·  ')}</div></div>`;
  }
  let any=false;
  for(const op of OPERARIOS) {
    const {total,machines}=getOcc(op); if(!machines.length) continue; any=true;
    const idx=OPERARIOS.indexOf(op); const color=OP_COLORS[idx]; const cc=occColor(total);
    c.innerHTML+=`<div class="op-card" style="border-color:${color}33">
      <div class="op-card-header"><span class="op-card-name" style="color:${color}">${op}</span><span class="op-card-total color-${cc}">${total.toFixed(0)}%</span></div>
      <div class="op-progress-wrap"><div class="op-progress" style="width:${Math.min(total,200)/2}%;background:${color}"></div></div>
      <div class="op-machines">${machines.map(m=>`<div class="op-machine-item"><span>${m.machId}</span><span>${m.molde} · ${m.coef}%</span></div>`).join('')}</div>
    </div>`;
  }
  if(!any&&!stopped.length) c.innerHTML='<p style="color:var(--text-dim);font-size:14px;text-align:center;padding:30px 0">Sin asignaciones aún</p>';
}

function togglePanel() { document.getElementById('op-panel').classList.toggle('open'); document.getElementById('overlay').classList.toggle('show'); renderPanel(); }
function closePanel()  { document.getElementById('op-panel').classList.remove('open'); document.getElementById('overlay').classList.remove('show'); }

document.getElementById('header-date').textContent = new Date().toLocaleDateString('es-ES',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
loadState(); renderTable(); updateAllOcu(); updateSummary();
</script>
</body>
</html>
